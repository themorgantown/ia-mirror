# Example environment variables for ia-mirror.
# Copy this file to docker/live.env and uncomment only the settings you need.
# docker-compose.yml reads docker/live.env if it exists; this file is a reference.

# Runtime mode
# Web UI is the default when WEB_ENABLED is blank or unset.
# In Web UI mode, leave IA_IDENTIFIER blank and paste item IDs/URLs in the browser.
# WEB_ENABLED=true

# Direct CLI mode requires a real identifier.
# Blank/missing IA_IDENTIFIER fails in CLI mode with "identifier required".
# Do not use IA_IDENTIFIER=example_item; it is placeholder text, not a valid setup.
# WEB_ENABLED=false
# IA_IDENTIFIER=The_Babe_Ruth_Collection
# IA_DRY_RUN=1

# Authentication (required for private items or uploads)
# IA_ACCESS_KEY=your_access_key_here
# IA_SECRET_KEY=your_secret_key_here

# Web UI settings
# Set WEB_SECRET_KEY explicitly in production to keep sessions stable across restarts.
# If unset, the app generates a random secret on startup.
# WEB_SECRET_KEY=replace_with_a_long_random_value
# WEB_HOST=0.0.0.0
# WEB_PORT=17865
# WEB_DB_PATH=/data/ui.db
# WEB_RUNNER=real

# Download defaults
# These apply to CLI mode and can also seed Web UI job defaults.
# IA_DESTDIR=/downloads
# IA_COLLECTION=1
# IA_GLOB=*.zip
# IA_CONCURRENCY=8
# IA_RETRIES=5
# IA_PROGRESS_TIMEOUT=1200
# IA_MAX_TIMEOUT=10800
# IA_RESUMEFOLDERS=1
# IA_CHECKSUM=1
## Bandwidth cap (off by default). Only applies if set to >0. Uses native Python throttling.
# IA_MAX_MBPS=200
# IA_ASSUMED_MBPS=200
# IA_COST_PER_GB=0.09

## Optional: append your app name/version to the Internet Archive User-Agent.
## Requires internetarchive >= 5.7.2.
# IA_USER_AGENT_SUFFIX=ia-archive-docker

## Health Check Server (optional)
# IA_HEALTH_PORT=8080

## Sync Mode (optional)
# IA_SYNC=1
## Additional filters (optional)
# IA_EXCLUDE=*.txt,*.nfo
# IA_FORMAT=mp3,flac
# IA_SOURCE=original
# IA_ON_THE_FLY=1
# IA_XML_NAMES=1
# IA_IGNORE_EXISTING=1
# IA_NO_DIRECTORIES=1
# IA_VERIFY_MODE=checksum
# IA_FORCE_METADATA_UPDATE=1
## Disable lockfile (not recommended)
# IA_NO_LOCK=1
## Batch mode (optional): two columns CSV `source,destdir`
# IA_USE_BATCH_SOURCE=1
# IA_BATCH_SOURCE_PATH=/app/batch_source.csv
# Set to 1 to only print estimates and exit
# IA_ESTIMATE_ONLY=1

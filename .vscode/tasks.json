{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build ia-mirror image",
			"type": "shell",
			"command": "docker",
			"args": [
				"build",
				"--pull",
				"--rm",
				"-f",
				"docker/Dockerfile",
				"-t",
				"ia-mirror:local",
				"docker"
			],
			"group": "build",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "Run ia-mirror and open Web UI",
			"type": "shell",
			"command": "sh",
			"args": [
				"-c",
				"docker-compose up -d && sleep 2 && open http://localhost:17865"
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": [],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		}
	]
}
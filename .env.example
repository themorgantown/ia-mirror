# ia-mirror: Docker Compose variable overrides
# Copy this file to .env in the same directory, then edit as needed.
# This file controls Docker Compose variable substitution (volumes, ports, etc.)
# It is NOT the same as docker/live.env — see README for the difference.

# ─── Download Location ────────────────────────────────────────────────────────
# Where downloaded files land on the HOST machine.
# Default: ./downloads (a folder created next to docker-compose.yml)
#
# IMPORTANT: Use full absolute paths. Tilde (~) is NOT expanded by Docker Compose.
#
# macOS:   DOWNLOAD_DIR=/Users/yourname/Downloads
# Windows: DOWNLOAD_DIR=C:/Users/yourname/Downloads
# Linux:   DOWNLOAD_DIR=/home/yourname/Downloads
#
# Paths with spaces must be quoted:
#   DOWNLOAD_DIR="/Users/yourname/My Downloads"
#
# After changing this value:
#   docker compose down && docker compose up -d
#
# DOWNLOAD_DIR=./downloads

# ─── Data Location ────────────────────────────────────────────────────────────
# Where the app database and metadata are stored on the HOST machine.
# Default: ./data (a folder created next to docker-compose.yml)
#
# DATA_DIR=./data
